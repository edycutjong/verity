# ── Verity (Vouch) — environment ──────────────────────────────────────────
# Copy to .env.local for Next.js (server-only) and .env for scripts. NEVER commit real values.

# Demo mode is ON by default. Set to "false" to broadcast real post_value/settle
# (pnpm settle) and use the real x402 facilitator for /api/value. See LIVE_TESTNET.md.
VERITY_DEMO=true
# Signing key algorithm for casper-js-sdk (ed25519 | secp256k1)
CASPER_KEY_ALGO=ed25519

# CSPR.cloud access token — obtain at https://cspr.cloud/ . Used as: Authorization: $CSPR_CLOUD_API_KEY
# Do NOT put this in any client/browser bundle.
CSPR_CLOUD_API_KEY=019eb506-c4cc-78c2-bde8-3ad969b76d57

# Casper Testnet (CAIP-2 casper:casper-test)
CASPER_NETWORK=casper-test
CASPER_NODE_RPC=https://node.testnet.cspr.cloud/rpc
CASPER_CHAIN_NAME=casper-test

# Oracle agent signing key (Testnet-only keypairs under data/keys/ for the deterministic demo).
CASPER_ORACLE_SECRET_KEY_PATH=./data/keys/oracle_secret_key.pem

# Verity contract (Odra, reputation registry).
VERITY_CONTRACT_HASH=

# x402 facilitator (CEP-18 micropayments for pay-per-query reads).
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud
X402_ASSET_PACKAGE=
X402_PAYEE_ADDRESS=
X402_CAIP2_CHAIN_ID=casper:casper-test

# Consumer account (pre-funded with CEP-18 token for demo x402 payment).
CONSUMER_PRIVATE_KEY_PATH=./data/keys/consumer_secret_key.pem

# Real Claude analyst over the oracle timeline (optional). With a key, /api/value
# includes a genuine LLM analysis (narrative + risk flags). Without one, analysis
# is null and the deterministic pipeline is unchanged.
ANTHROPIC_API_KEY=
# VERITY_ANALYST_MODEL=claude-haiku-4-5

# ── Optional overrides (sensible defaults; uncomment only to tune) ────────────
# CASPER_CALL_PAYMENT_MOTES=5000000000   # gas limit per contract entry-point call (default 5 CSPR)
